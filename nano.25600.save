version: "3.8"

services:
  mysql:
    image: mysql:8.0
    container_name: bank-mysql
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: bank_management_system_springboot
      MYSQL_USER: bank_user
      MYSQL_PASSWORD: bank_password
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql

  redis:
    image: redis:7-alpine
    container_name: bank-redis
    ports:
      - "6379:6379"

  backend:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: bank-backend
    environment:
      MYSQL_HOST: mysql
      MYSQL_PORT: 3306
      MYSQL_DB: bank_management_system_springboot
      DB_USERNAME: bank_user
      DB_PASSWORD: bank_password
      REDIS_HOST: redis
      REDIS_PORT: 6379
      FRONTEND_URL: http://localhost:3000
      PORT: 8080
    depends_on:
      - mysql
      - redis
    ports:
      - "8080:8080"

  frontend:
    build:
      context: ./Frontend
      dockerfile: Dockerfile
    container_name: bank-frontend
    depends_on:
      - backend
    ports:
      - "3000:80"    # maps host 3000 to nginx port 80 inside container
    environment:
      - REACT_APP_API_BASE_URL=http://localhost:8080
    restart: unless-stopped

volumes:
  mysql_data:
